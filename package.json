{
  "name": "recipe-generator",
  "version": "1.0.0",
  "scripts": {
    "start:gateway": "cd backend/gateway && npm run dev",
    "start:recipe": "cd backend/services/recipe && npm run dev",
    "start:mood": "cd backend/services/mood && npm run dev",
    "start:frontend": "cd frontend && npm run dev",
    "dev": "concurrently \"npm run start:gateway\" \"npm run start:recipe\" \"npm run start:mood\" \"npm run start:frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "dotenv": "^17.4.1"
  }
}
